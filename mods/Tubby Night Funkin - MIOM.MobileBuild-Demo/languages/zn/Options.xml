		<str id="optionsTree.controls-desc">更改玩家1和玩家2的控制设置！</str>

		<str id="optionsTree.gameplay-name">游戏玩法</str>
		<str id="optionsTree.gameplay-desc">更改游戏玩法选项，如下落式音符、滚动速度、粗俗内容过滤...</str>
		<str id="optionsTree.gameplay.advanced-desc">更改更高级的选项，如流式音频...</str>

		<str id="optionsTree.appearance-name">外观</str>
		<str id="optionsTree.appearance-desc">更改外观选项，如菜单闪烁效果...</str>
		<str id="optionsTree.appearance.advanced-desc">更改更高级的选项，如仅显存精灵、抗锯齿、着色器。</str>

		<str id="optionsTree.language-name">语言</str>
		<str id="optionsTree.language-desc">更改引擎使用的语言。</str>

		<str id="optionsTree.miscellaneous-name">杂项</str>
		<str id="optionsTree.miscellaneous-desc">使用此菜单重置存档数据或引擎设置。</str>

		<str id="optionsTree.debug-name">调试选项</str>
		<str id="optionsTree.debug-desc">开发者模式的调试选项。</str>

		<str id="optionsTree.mobile-name">移动端选项</str>
		<str id="optionsTree.mobile-desc">更改与移动设备或触摸控制相关的选项。</str>
	</group>

